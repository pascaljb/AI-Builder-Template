# ─────────────────────────────────────────────────────────────
# Environment variables — copy this to .env.local and fill in
# Run: cp .env.template .env.local
#
# Where to find each value:
#   Supabase Dashboard → Project Settings → API
#   https://app.supabase.com/project/[your-project]/settings/api
# ─────────────────────────────────────────────────────────────

# Your Supabase project URL
# Format: https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anon/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Optional ────────────────────────────────────────────────

# Only needed for server-side admin operations (never expose to browser)
# Supabase Dashboard → Project Settings → API → service_role key
# SUPABASE_SERVICE_ROLE_KEY=

# App URL (used for auth redirects)
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
